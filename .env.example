# Pelleto AI — Environment
# Копируй в .env и заполни
# NEVER commit .env to git!

# ─ FastAPI
FLASK_ENV=production
SECRET_KEY=change-me-32-chars-random-string!!

# ─ Admin auth
# Сгенерировать: python3 -c "import bcrypt; print(bcrypt.hashpw(b'your-key', bcrypt.gensalt(12)).decode())"
MASTER_KEY_HASH=$2b$12$REPLACE_WITH_BCRYPT_HASH
SESSION_LIFETIME_HOURS=24

# ─ Gemini
GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=10
GEMINI_MAX_TOKENS=1500

# ─ Telegram
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
TELEGRAM_ADMIN_CHAT_ID=REPLACE_WITH_CHAT_ID

# ─ Database
DB_PATH=./data/pelleto.db
DB_BUSY_TIMEOUT_MS=5000

# ─ Agent
AGENT_ENABLED=true
AGENT_MAX_QUESTION_LEN=500
AGENT_MAX_HISTORY=10

# ─ Site
SITE_NAME=Тёплый Склад
SITE_PHONE=+7 (999) 123-45-67
SITE_ADDRESS=Москва и МО
SITE_VERSION=1.0.0
ORDER_URL=/order
PORT=8130